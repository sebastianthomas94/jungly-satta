# Server port
PORT=3001

# JWT secret for authentication (change in production!)
JWT_SECRET=change-me-in-production

# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/youtube/callback

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Game timing (in milliseconds)
ROUND_DURATION_MS=30000
BETTING_CUTOFF_MS=5000
RESULT_DISPLAY_MS=3000

# Database URL (SQLite for dev, change for production)
DATABASE_URL=file:./dev.db

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret